{
  "bomFormat": "CycloneDX",
  "specVersion": "1.6",
  "version": 1,
  "metadata": {
    "component": {
      "type": "device",
      "name": "Reverse Proxy"
    }
  },
  "components": [
    {
      "type": "operating-system",
      "name": "Ubuntu",
      "version": "20.04.5",
      "purl": "pkg:generic/canonical/ubuntu@20.04.5"
    },
    {
      "type": "application",
      "name": "nginx",
      "version": "1.18.0",
      "purl": "pkg:generic/nginx/nginx@1.18.0"
    }
  ],
  "services": [
    {"name": "HTTP", "endpoints": ["tcp://0.0.0.0:80"]},
    {"name": "HTTPS", "endpoints": ["tcp://0.0.0.0:443"]}
  ],
  "vulnerabilities": [
    {
      "id": "CVE-2021-23017",
      "description": "nginx resolver 1-byte memory overwrite via crafted DNS response — potential RCE",
      "ratings": [{"severity": "high", "score": 7.7, "method": "CVSSv3"}],
      "affects": [{"ref": "Reverse Proxy"}]
    }
  ],
  "properties": [
    {"name": "secopstm:patch_level", "value": "outdated"},
    {"name": "secopstm:detection_level", "value": "low"},
    {"name": "secopstm:credentials_stored", "value": "false"},
    {"name": "secopstm:notes", "value": "nginx not updated since 2021. Terminates TLS but backend is HTTP."}
  ]
}
