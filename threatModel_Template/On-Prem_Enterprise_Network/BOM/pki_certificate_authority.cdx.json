    {
      "id": "CVE-2021-36942",
      "description": "PetitPotam — unauthenticated NTLM relay attack forcing domain controller to authenticate to AD CS",
      "ratings": [{"severity": "high", "score": 7.5, "method": "CVSSv3"}],
      "affects": [{"ref": "PKI Certificate Authority"}]
    }
  ],
  "properties": [
    {"name": "secopstm:patch_level", "value": "outdated"},
    {"name": "secopstm:detection_level", "value": "low"},
    {"name": "secopstm:credentials_stored", "value": "true"},
    {"name": "secopstm:notes", "value": "ESC1 and ESC8 AD CS misconfigurations not remediated. PetitPotam relay path available."}
  ]
}
