{
  "bomFormat": "CycloneDX",
  "specVersion": "1.6",
  "version": 1,
  "metadata": {
    "component": {
      "type": "device",
      "name": "File Server"
    }
  },
  "components": [
    {
      "type": "operating-system",
      "name": "Windows Server 2019",
      "version": "10.0.17763",
      "purl": "pkg:generic/microsoft/windows-server@10.0.17763"
    },
    {
      "type": "application",
      "name": "Windows File Services",
      "version": "10.0.17763"
    }
  ],
  "services": [
    {"name": "SMB", "endpoints": ["tcp://0.0.0.0:445"]},
    {"name": "NETBIOS", "endpoints": ["tcp://0.0.0.0:139"]},
