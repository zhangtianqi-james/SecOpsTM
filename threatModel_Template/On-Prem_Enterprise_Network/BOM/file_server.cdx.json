    {
      "id": "CVE-2017-0144",
      "description": "EternalBlue — Windows SMBv1 remote code execution via crafted transaction request",
      "ratings": [{"severity": "critical", "score": 9.8, "method": "CVSSv3"}],
      "affects": [{"ref": "File Server"}]
    }
  ],
  "properties": [
    {"name": "secopstm:patch_level", "value": "outdated"},
    {"name": "secopstm:detection_level", "value": "low"},
    {"name": "secopstm:credentials_stored", "value": "false"},
    {"name": "secopstm:notes", "value": "SMBv1 still enabled for legacy printer compatibility. Network share ACLs not reviewed in 2 years."}
  ]
